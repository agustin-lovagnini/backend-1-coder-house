<h1>Carrito</h1>

<p>ID del carrito: {{cart._id}}</p>

{{#if cart.products.length}}
    <ul>
        {{#each cart.products}}
        <li>
            {{this.product.title}} - ${{this.product.price}} | Cantidad: {{this.quantity}}
        </li>
        {{/each}}
    </ul>
{{else}}
    <p>El carrito no tiene productos.</p>
{{/if}}
