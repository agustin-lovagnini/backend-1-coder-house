<h1>Productos</h1>

{{#if query}}
<p>Filtro aplicado: {{query}}</p>
{{/if}}

{{#if sort}}
<p>Orden por precio: {{sort}}</p>
{{/if}}

<ul>
    {{#each products}}
    <li>
        <h3>{{this.title}}</h3>
        <p>Precio: ${{this.price}}</p>

        <a href="/products/{{this._id}}">Ver detalle</a>

        <form onsubmit="addToCart(event, '{{../cartId}}', '{{this._id}}')">
            <button type="submit">Agregar al carrito</button>
        </form>
    </li>
    {{/each}}
</ul>

<div>
    {{#if hasPrevPage}}
    <a href="/products?page={{prevPage}}{{extraQuery}}">&larr; Anterior</a>
    {{/if}}

    Pagina {{page}} de {{totalPages}}

    {{#if hasNextPage}}
    <a href="/products?page={{nextPage}}{{extraQuery}}">Siguiente &rarr;</a>
    {{/if}}
</div>

<script>
    function addToCart(event, cartId, productId) {
        event.preventDefault(); // Evita que el formulario se envíe normalmente

        fetch(`/api/carts/${cartId}/products/${productId}`, {
            method: "POST"
        })
        .then(res => {
            if (!res.ok) {
                throw new Error("No se pudo agregar el producto");
            }
            return res.json();
        })
        .then(() => {
            window.location.href = `/carts/${cartId}`;
        })
        .catch(err => {
            console.error(err);
            alert("No se pudo agregar al carrito");
        });
    }
</script>
